# ─────────────────────────────────────────────────────────────
# roguelike-td — root .gitignore
# Covers: Python (balance/), Godot (client/), server/, OS junk.
# ─────────────────────────────────────────────────────────────

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.python-version
build/
dist/
*.egg-info/
.eggs/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# uv / poetry local files
# 注意：本项目是「应用」而非「库」，uv.lock 应当提交以保证环境一致。
# 仅保留 .python-version 的本地覆盖被忽略（如有）。
local.python-version

# ── Godot (client/) ──
# Godot generates these per-machine; never commit them.
.godot/
*.import
export.cfg
export_presets.cfg
# OS-specific Godot editor cruft
._*
.DS_Store

# ── Node / server (if server/ uses Node) ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.pnp.*

# ── Go (if server/ uses Go) ──
*.exe
*.exe~
*.dll
*.dylib
*.test
*.out
bin/

# ── General / OS ──
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.tmp
*.log
*.swp
*.swo
*~

# ── Editor / IDE ──
.vscode/
.idea/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/

# ── Generated balance reports (keep dir, ignore artifacts) ──
balance/reports/out/

# ── Generated static site (CI 生成，源是 SSOT) ──
site/
